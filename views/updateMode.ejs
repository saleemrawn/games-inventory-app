<div class="container-xxl">
  <h1><%= title %></h1>
  <%- include("./partials/errors.ejs") %>
  <form action="/modes/edit/<%= mode.id %>" method="post" class="bg-white p-4 mt-4">
    <input type="hidden" name="modeId" value="<%= mode.id %>" />
    <div class="mb-5">
      <label for="modeName" class="form-label fs-5" aria-describedby="modeNameHelpBlock">Name</label>
      <input type="text" id="modeName" class="form-control" name="modeName" value="<%= mode.name %>" />
      <div id="modeNameHelpBlock" class="form-text mt-2">Name must only contain letters, numbers, '/&-</div>
    </div>
    <button type="submit" class="btn btn-primary btn-lg">Submit</button>
  </form>
</div>
